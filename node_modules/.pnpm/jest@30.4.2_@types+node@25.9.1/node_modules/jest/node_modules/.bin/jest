#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/sharpish/code-lab/anthropic-cli-tool/node_modules/.pnpm/jest@30.4.2_@types+node@25.9.1/node_modules/jest/node_modules:/home/sharpish/code-lab/anthropic-cli-tool/node_modules/.pnpm/jest@30.4.2_@types+node@25.9.1/node_modules:/home/sharpish/code-lab/anthropic-cli-tool/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/sharpish/code-lab/anthropic-cli-tool/node_modules/.pnpm/jest@30.4.2_@types+node@25.9.1/node_modules/jest/node_modules:/home/sharpish/code-lab/anthropic-cli-tool/node_modules/.pnpm/jest@30.4.2_@types+node@25.9.1/node_modules:/home/sharpish/code-lab/anthropic-cli-tool/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../bin/jest.js" "$@"
else
  exec node  "$basedir/../../bin/jest.js" "$@"
fi
